# ==============================================
# .env — Maxfiy sozlamalar fayli
# Bu faylni GitHub ga HECH QACHON yuklamang!
# .gitignore ga qo'shing: echo ".env" >> .gitignore
# ==============================================

# Django asosiy sozlamalar
SECRET_KEY=django-insecure-bu-yerga-o'z-secret-key-ingizni-yozing-123456789
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Ma'lumotlar bazasi (production uchun PostgreSQL)
DB_NAME=mydb
DB_USER=postgres
DB_PASSWORD=secret_parol_123
DB_HOST=localhost
DB_PORT=5432

# Email sozlamalari (Gmail misoli)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=myapp@gmail.com
EMAIL_HOST_PASSWORD=abcd_efgh_ijkl_mnop

# Twilio SMS sozlamalari
account_sid=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
auth_token=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
